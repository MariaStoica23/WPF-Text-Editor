<Window x:Class="NotepadDemo.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NotepadDemo.Views"
        mc:Ignorable="d"
        Title="About" Height="240" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="20" VerticalAlignment="Center">

        <TextBlock Text="NotepadDemo"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,5"/>

        <TextBlock Text="A simple Notepad++ inspired editor"
                   FontSize="12"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <TextBlock Text="Autor: Stoica Anna Maria"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,5"/>

        <Button Content="Close"
                Width="80"
                Margin="0,20,0,0"
                HorizontalAlignment="Center"
                IsCancel="True"
                Click="Close_Click"/>

    </StackPanel>
</Window>
