<Window x:Class="NotepadDemo.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NotepadDemo.Views"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="150" Width="350" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="15">
        <TextBlock Text="{Binding Prompt}" Margin="0,0,0,8"/>
        <TextBox Name="inputTxt" Margin="0,0,0,12"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK"     Width="70" Margin="0,0,8,0" Click="Ok_Click"     IsDefault="True"/>
            <Button Content="Cancel" Width="70"                  Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
