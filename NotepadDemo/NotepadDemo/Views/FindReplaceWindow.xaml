<Window x:Class="NotepadDemo.Views.FindReplaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NotepadDemo.Views"
        xmlns:behaviors="clr-namespace:NotepadDemo.Behaviors"
        mc:Ignorable="d"
        Title="{Binding Search.FindReplaceTitle}"
        Height="250" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Closing="Window_Closing"
        Icon="..\Assets\magnifyingGlass.png">
    <TabControl Margin="10" Name="tabControl"
            behaviors:TabControlTitleBehavior.Titles="Find|Replace">
        <TabItem Header="Find">
            <StackPanel Margin="10">

                <WrapPanel Margin="0,0,0,8">
                    <Label Width="80" Content="Find:"/>
                    <TextBox Width="270"
                     Text="{Binding Search.SearchText,
                            UpdateSourceTrigger=PropertyChanged}"/>
                </WrapPanel>

                <WrapPanel Margin="0,0,0,8">
                    <Label Width="80"/>
                    <CheckBox Content="Match case"
                      IsChecked="{Binding Search.MatchCase}"
                      Margin="0,0,15,0"/>
                    <CheckBox Content="Search in all tabs"
                      IsChecked="{Binding Search.SearchInAllTabs}"/>
                </WrapPanel>

                <WrapPanel Margin="0,0,0,12">
                    <Label Width="80"/>
                    <TextBlock Text="{Binding Search.StatusMessage}"
                       Foreground="Gray"
                       FontStyle="Italic"
                       VerticalAlignment="Center"/>
                </WrapPanel>

                <WrapPanel HorizontalAlignment="Right">
                    <Button Content="Find Next"
                    Width="90" Margin="0,0,8,0"
                    IsDefault="True"
                    Command="{Binding Search.FindCommand}"/>
                    <Button Content="Close"
                    Width="90"
                    IsCancel="True"
                    Click="Close_Click"/>
                </WrapPanel>

            </StackPanel>
        </TabItem>

        <TabItem Header="Replace">
            <StackPanel Margin="10">

                <WrapPanel Margin="0,0,0,8">
                    <Label Width="80" Content="Find:"/>
                    <TextBox Width="270"
                     Text="{Binding Search.SearchText,
                            UpdateSourceTrigger=PropertyChanged}"/>
                </WrapPanel>

                <WrapPanel Margin="0,0,0,8">
                    <Label Width="80" Content="Replace:"/>
                    <TextBox Width="270"
                     Text="{Binding Search.ReplaceText,
                            UpdateSourceTrigger=PropertyChanged}"/>
                </WrapPanel>

                <WrapPanel Margin="0,0,0,8">
                    <Label Width="80"/>
                    <CheckBox Content="Match case"
                      IsChecked="{Binding Search.MatchCase}"
                      Margin="0,0,15,0"/>
                    <CheckBox Content="Search in all tabs"
                      IsChecked="{Binding Search.SearchInAllTabs}"/>
                </WrapPanel>

                <WrapPanel Margin="0,0,0,12">
                    <Label Width="80"/>
                    <TextBlock Text="{Binding Search.ReplaceStatusMessage}"
                       Foreground="Gray"
                       FontStyle="Italic"
                       VerticalAlignment="Center"/>
                </WrapPanel>

                <WrapPanel HorizontalAlignment="Right">
                    <Button Content="Replace"
                    Width="90" Margin="0,0,8,0"
                    IsDefault="True"
                    Command="{Binding Search.ReplaceCommand}"/>
                    <Button Content="Replace All"
                    Width="90" Margin="0,0,8,0"
                    Command="{Binding Search.ReplaceAllCommand}"/>
                    <Button Content="Close"
                    Width="90"
                    IsCancel="True"
                    Click="Close_Click"/>
                </WrapPanel>

            </StackPanel>
        </TabItem>

    </TabControl>
</Window>
